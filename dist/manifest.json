{
  "manifest_version": 3,
  "name": "MYT Event Inspector",
  "version": "1.1.0",
  "description": "Real-time Timeline Event inspector for myyogateacher.com",
  "author": "Rahul Bohra",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "*://myyogateacher.com/*",
    "*://student-testenv1.myyogateacher.com/*",
    "*://student-testenv2.myyogateacher.com/*"
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/interceptor.js-CvmTZwdA.js"
      ],
      "matches": [
        "*://myyogateacher.com/*",
        "*://student-testenv1.myyogateacher.com/*",
        "*://student-testenv2.myyogateacher.com/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": [
        "assets/index.js-BQjvCs1K.js"
      ],
      "matches": [
        "*://myyogateacher.com/*",
        "*://student-testenv1.myyogateacher.com/*",
        "*://student-testenv2.myyogateacher.com/*"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Open MYT Event Inspector",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://myyogateacher.com/*",
        "*://student-testenv1.myyogateacher.com/*",
        "*://student-testenv2.myyogateacher.com/*"
      ],
      "resources": [
        "src/injected/interceptor.js",
        "assets/interceptor.js-CvmTZwdA.js",
        "assets/index.js-BQjvCs1K.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
